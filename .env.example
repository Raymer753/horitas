# ──────────────────────────────────────────────
# Horitas v2 — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# cp .env.example .env
# ──────────────────────────────────────────────

# REQUIRED — Discord bot token from https://discord.com/developers
DISCORD_TOKEN=tu_token_aqui

# OPTIONAL — Command prefix for text commands (default: !)
# BOT_PREFIX=!

# OPTIONAL — Default timezone for announcements (default: Europe/Madrid)
# DEFAULT_TZ=Europe/Madrid

# OPTIONAL — Python logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# OPTIONAL — Path to audio files directory (default: /app/audio in Docker)
# AUDIO_DIR=/app/audio

# OPTIONAL — Path to persistent data directory (default: /app/data in Docker)
# DATA_DIR=/app/data

# ──────────────────────────────────────────────
# Admin Panel (only needed if using docker-compose.admin.yml)
# ──────────────────────────────────────────────

# REQUIRED for admin — Password to access the admin panel
# ADMIN_PASSWORD=tu_contraseña_aqui

# OPTIONAL — Secret key for Flask sessions (auto-generated if not set)
# ADMIN_SECRET_KEY=cambiar_esto_en_produccion

